{
	"name": "rundown",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@11.13.1",
	"scripts": {
		"dev": "concurrently -c auto -n 'next,docker,studio' 'next dev --turbopack --experimental-https' 'docker compose up' 'drizzle-kit studio'",
		"devf": "next dev --turbopack --experimental-https",
		"build": "next build",
		"start": "next start",
		"lint": "biome check",
		"lintf": "biome check --write --unsafe",
		"bull-board": "tsx server/controllers/bull-board.ts",
		"db:push": "drizzle-kit push",
		"prod:worker": "tsx server/controllers/worker.ts",
		"prod:register-jobs": "tsx server/controllers/register-jobs.ts",
		"build:worker": "esbuild server/controllers/worker.ts --bundle --platform=node --target=node22 --outfile=build/services/worker.js",
		"bootstrap": "drizzle-kit push",
		"crawl": "tsx server/controllers/crawl.ts",
		"typecheck": "tsc"
	},
	"dependencies": {
		"@bull-board/api": "^6.12.0",
		"@bull-board/express": "^6.12.0",
		"@modelcontextprotocol/sdk": "1.26.0",
		"@next/env": "^16.0.7",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-dialog": "^1.1.14",
		"@radix-ui/react-dropdown-menu": "^2.1.15",
		"@radix-ui/react-label": "^2.1.7",
		"@radix-ui/react-navigation-menu": "^1.2.13",
		"@radix-ui/react-radio-group": "^1.3.7",
		"@radix-ui/react-scroll-area": "^1.2.9",
		"@radix-ui/react-select": "^2.2.5",
		"@radix-ui/react-separator": "^1.1.7",
		"@radix-ui/react-slot": "^1.2.3",
		"@radix-ui/react-tabs": "^1.1.12",
		"@radix-ui/react-tooltip": "^1.2.7",
		"@slack/bolt": "^4.4.0",
		"@slack/logger": "^4.0.0",
		"@slack/oauth": "^3.0.3",
		"@slack/web-api": "^7.9.3",
		"@slack/webhook": "^7.0.5",
		"better-auth": "^1.6.23",
		"bullmq": "5.80.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"express": "^5.1.0",
		"lucide-react": "^0.536.0",
		"mcp-handler": "^1.1.0",
		"nanoid": "^5.1.5",
		"next": "^16.2.10",
		"next-themes": "^0.4.6",
		"openai": "^5.12.2",
		"pg": "^8.16.3",
		"react": "19.1.1",
		"react-dom": "19.1.1",
		"react-markdown": "^10.1.0",
		"rss-parser": "^3.13.0",
		"simple-icons": "^15.10.0",
		"slackify-markdown": "^4.5.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.3.1",
		"tsscmp": "^1.0.6",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.3",
		"@tailwindcss/postcss": "^4.1.11",
		"@tailwindcss/typography": "^0.5.16",
		"@types/express": "^5.0.3",
		"@types/node": "^20.19.9",
		"@types/react": "^19.1.9",
		"@types/react-dom": "^19.1.7",
		"@types/tsscmp": "^1.0.2",
		"concurrently": "^9.2.0",
		"drizzle-kit": "^0.31.10",
		"esbuild": "^0.25.8",
		"tailwindcss": "^4.1.11",
		"tsx": "^4.20.3",
		"tw-animate-css": "^1.3.6",
		"typescript": "^6.0.3"
	}
}
